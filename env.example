# ── Ports ─────────────────────────────────────────────────────────────────────
GATEWAY_PORT=REPLACE_WITH_YOURS
AUTH_PORT=REPLACE_WITH_YOURS
SONGS_PORT=REPLACE_WITH_YOURS
STREAMING_PORT=REPLACE_WITH_YOURS
PLAYLISTS_PORT=REPLACE_WITH_YOURS

# ── MongoDB ───────────────────────────────────────────────────────────────────
# "mongo" is the Docker service name — it resolves to the container internally
MONGO_URI=mongodb://mongo:27017
AUTH_DB=auth_db
SONGS_DB=songs_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_random_secret
JWT_REFRESH_SECRET=replace_with_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# "rabbitmq" is the Docker service name
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ── Audio Storage ─────────────────────────────────────────────────────────────
# Path inside the container — matches the volume mount in docker-compose.yml
AUDIO_STORAGE_PATH=REPLACE_WITH_YOURS

# ── Service URLs (used by the gateway to forward requests) ────────────────────
AUTH_SERVICE_URL=http://auth:3001
SONGS_SERVICE_URL=http://songs:3002
STREAMING_SERVICE_URL=http://streaming:3003
PLAYLISTS_SERVICE_URL=http://playlists:3004
